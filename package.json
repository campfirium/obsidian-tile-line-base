{
  "name": "obsidian-tile-line-base",
  "version": "0.9.15",
  "description": "Build multidimensional tables (Tables, Kanban, Gallery, Slides) directly from plain text. Zero Frontmatter. Zero code.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run lint && npm run check:css-important && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run check:release",
    "build:low": "nice -n 19 ionice -c3 npm run build",
    "build:sync": "npm run build && npm run mirror:obs -- --prefer=plugin-dir",
    "build:sync:low": "nice -n 19 ionice -c3 npm run build && npm run mirror:obs -- --prefer=plugin-dir",
    "deps:hardening:check": "node scripts/deps-hardening-check.mjs",
    "deps:scan": "node scripts/deps-scan.mjs",
    "lint": "node scripts/run-lint.mjs",
    "check:css-important": "node scripts/check-css-important.mjs",
    "check:i18n-hardcoded": "node scripts/check-i18n-hardcoded.mjs",
    "test:magic": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\"}' .lab/scripts/test-magic-migration.ts",
    "verify:column-service": "ts-node --require ./scripts/dev/runtime-globals.cjs --transpile-only --compiler-options '{\"module\":\"commonjs\"}' scripts/dev/verify-column-service.ts",
    "verify:interaction-controller": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' ts-node --require ./scripts/dev/runtime-globals.cjs scripts/dev/verify-interaction-controller.ts",
    "verify:lifecycle-manager": "ts-node --require ./scripts/dev/runtime-globals.cjs --transpile-only --compiler-options '{\"module\":\"commonjs\"}' scripts/dev/verify-lifecycle-manager.ts",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "deploy:wsl": "npm run build && node scripts/deploy-wsl.mjs",
    "mirror:obs": "node .lab/scripts/mirror-obs.mjs",
    "mirror:obs-vault": "node .lab/scripts/mirror-obs-vault.mjs",
    "mirror:demo": "node .lab/scripts/mirror-demo.mjs",
    "version": "node version-bump.mjs && git add package.json manifest.json versions.json",
    "check:release": "node scripts/check-release.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "database",
    "table"
  ],
  "author": "Campfirium",
  "license": "MIT",
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/js": "9.39.0",
    "@eslint/json": "0.14.0",
    "@types/node": "16.18.126",
    "@types/sortablejs": "1.15.9",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "esbuild": "0.25.12",
    "eslint": "9.39.0",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-obsidianmd": "0.3.0",
    "jsonc-eslint-parser": "2.4.1",
    "obsidian": "1.8.7",
    "terser": "5.44.1",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2"
  },
  "dependencies": {
    "ag-grid-community": "34.2.0",
    "monkey-around": "3.0.0",
    "sortablejs": "1.15.6"
  }
}
